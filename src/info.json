{
  "identifier": "wordbook-bob-plugin",
  "version": "0.2.4",
  "category": "translate",
  "name": "单词本插件",
  "summary": "word book plugin, add word to youdao/eudic/shanbay/momo word book",
  "icon": "",
  "author": "Eric_余浩",
  "homepage": "https://blog.yuhaowin.com/2021-01-03-wordbook-bob-plugin",
  "appcast": "https://raw.githubusercontent.com/yuhaowin/wordbook-bob-plugin/main/appcast.json",
  "minBobVersion": "1.12.0",
  "options": [
    {
      "identifier": "dict_type",
      "type": "menu",
      "title": "词典类型",
      "defaultValue": "1",
      "menuValues": [
        {
          "title": "有道词典",
          "value": "1"
        },
        {
          "title": "欧路词典",
          "value": "2"
        },
        {
          "title": "扇贝单词",
          "value": "3"
        },
        {
          "title": "Momo背单词",
          "value": "4"
        }
      ]
    },
    {
      "identifier": "authorization",
      "type": "text",
      "title": "认证信息",
      "textConfig": {
        "type": "secure",
        "placeholderText": "填写 api token"
      }
    },
    {
      "identifier": "word_only",
      "type": "menu",
      "title": "仅保存单词",
      "desc": "是否仅保存「单词」或「词组」。",
      "defaultValue": "1",
      "menuValues": [
        {
          "title": "是",
          "value": "1"
        },
        {
          "title": "否",
          "value": "0"
        }
      ]
    },
    {
      "identifier": "wordbook_id",
      "type": "text",
      "title": "单词本 ID",
      "desc": "「欧路词典」填写单词本 ID；「Momo背单词」填写云词本 ID（在墨墨 App「我的 > 更多设置 > 实验功能 > 开放 API」查看）。",
      "textConfig": {
        "type": "visible",
        "placeholderText": "欧路词典点击「验证」获取；Momo 在 App 开放 API 页面查看"
      }
    }
  ]
}
